# ArchAI — miljøvariabler
# Kopiér denne fil til .env.local og udfyld dine egne værdier.
# .env.local er gitignored og må indeholde rigtige hemmeligheder.

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://din-projekt-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=din_service_role_key_her
SUPABASE_PUBLISHABLE_KEY=din_publishable_key_her

# Klient-side (VITE_-prefix gør dem tilgængelige i browseren)
VITE_SUPABASE_URL=https://din-projekt-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=din_publishable_key_her
VITE_SUPABASE_PROJECT_ID=din-projekt-id

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-din_nøgle_her

# ── Datafordeler ──────────────────────────────────────────────────────────────
DATAFORDELER_API_KEY=din_datafordeler_nøgle_her

# ── Sentry ────────────────────────────────────────────────────────────────────
# Hent DSN fra Sentry: Settings → Projects → archai-design-partner → Client Keys
SENTRY_DSN=https://xxx@oXXXXXX.ingest.de.sentry.io/XXXXXXX
# ENVIRONMENT=production  # Sættes automatisk af deploy-pipeline

# Valgfri endpoints (har fornuftige standardværdier hvis ikke sat):
# DATAFORDELER_BBR_ENDPOINT=https://graphql.datafordeler.dk/BBR/v2
# DATAFORDELER_MAT_ENDPOINT=https://graphql.datafordeler.dk/MAT/v2
# DATAFORDELER_DAR_ENDPOINT=https://graphql.datafordeler.dk/DAR/v1
